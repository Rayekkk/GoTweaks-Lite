                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Saved Profiles"
                                       FontSize="16"
                                       Foreground="#00C8FF"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <!--
                                Sort dropdown for the saved-profiles list. Selection is
                                persisted to LocalSettings["ProfileSortMode"] so it
                                survives across widget re-opens. Tags are read by the
                                C# code-behind in UpdateAllGameProfilesDisplay to drive
                                ordering.
                            -->
                            <ComboBox x:Name="ProfileSortComboBox"
                                      Grid.Column="1"
                                      Width="150"
                                      SelectionChanged="ProfileSortComboBox_SelectionChanged"
                                      Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Tag="name" Content="Name (A→Z)" IsSelected="True"/>
                                <ComboBoxItem Tag="modified" Content="Last Modified"/>
                                <ComboBoxItem Tag="tdp" Content="TDP (high → low)"/>
                            </ComboBox>
                        </Grid>

                        <!-- Container for dynamically created game profile cards -->
                        <StackPanel x:Name="AllGameProfilesContainer"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- GRAPHICS TAB -->
                <ScrollViewer x:Name="AMDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Resolution Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Resolution"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="ResolutionComboBox"
                                          PlaceholderText="1920x1080"
                                          Width="150"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusUp="{x:Bind GraphicsNavItem}">
                                    <x:String>1920x1080</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Refresh Rate Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Refresh Rate"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="RefreshRatesComboBox"
                                          PlaceholderText="60 Hz"
                                          Width="120"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusUp="{x:Bind GraphicsNavItem}">
                                    <x:String>60 Hz</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- HDR Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="HDR" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="High Dynamic Range" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="HDRToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- Auto SDR (Go2HDR) — matches the SDR white level to screen
                                     brightness while HDR is active so SDR content isn't washed
                                     out. No effect while HDR is off. -->
                                <Border Margin="0,12,0,0" Height="1" Background="#22FFFFFF"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Auto SDR" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Match SDR brightness to screen brightness (HDR only)" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AutoSdrToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Adaptive Brightness Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Adaptive Brightness" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Auto-adjust based on ambient light (requires sensor)" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AdaptiveBrightnessToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="AdaptiveBrightnessToggle_Toggled"/>
                                </Grid>

                                <!-- Mode picker collapses behind a chevron when the toggle is on, so the
                                     card shows only "Adaptive Brightness + toggle" by default. Expander
                                     row itself is hidden until the master toggle is on. -->
                                <Grid Margin="0,12,0,0"
                                      Visibility="{Binding ElementName=AdaptiveBrightnessToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Engine &amp; details"
                                               FontSize="12" Foreground="#B9C0CC"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton x:Name="AdaptiveBrightnessExpanderToggle"
                                                  Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                  Padding="8,4" Click="AdaptiveBrightnessExpanderToggle_Click">
                                        <FontIcon x:Name="AdaptiveBrightnessExpanderIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="AdaptiveBrightnessPanel"
                                            Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Mode"
                                                   FontSize="13" Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="AdaptiveBrightnessModeComboBox"
                                                  Grid.Column="1"
                                                  Width="170"
                                                  Style="{StaticResource ModernComboBoxStyle}">
                                            <x:String>Windows</x:String>
                                            <x:String>Helper (learns)</x:String>
                                        </ComboBox>
                                    </Grid>
                                    <TextBlock Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="#888888">
                                        <Run FontWeight="SemiBold" Foreground="#B9C0CC" Text="Windows"/>
                                        <Run Text=" — uses the OS adaptive brightness service (ADAPTBRIGHT). Slow, opaque, single hard-coded curve, no learning."/>
                                        <LineBreak/>
                                        <Run FontWeight="SemiBold" Foreground="#B9C0CC" Text="Helper (learns)"/>
                                        <Run Text=" — reads the ALS directly. One-Euro-filtered lux signal, log lux → brightness curve, sustained-change requirement before reacting (won't twitch on transient flashes), direction-aware response (brightens quickly when entering a darker space, dims slowly to avoid flicker), smooth eased transitions instead of stepped jumps, lux-ratio override hold (your manual adjustment sticks until ambient changes by 2×). Each time you nudge the slider, the helper learns your preferred offset for that ambient range (six log-spaced lux buckets) and biases future predictions toward what you picked. Switching to Helper turns Windows ADAPTBRIGHT off so the two don't fight."/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Display Color Settings Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Color Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Adjust display color output" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <Button x:Name="ColorSettingsExpandButton"
                                            Grid.Column="1"
                                            Content="&#xE70D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Padding="8,4"
                                            Background="Transparent"
                                            Click="ColorSettingsExpandButton_Click"
                                            UseSystemFocusVisuals="True"
                                            FocusVisualPrimaryBrush="White"/>
                                </Grid>
                                <StackPanel x:Name="ColorSettingsContent" Visibility="Collapsed" Margin="0,10,0,0">
                                    <Slider x:Name="AMDDisplayBrightnessSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="-100" Maximum="100"
                                            StepFrequency="1"
                                            Header="Brightness"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDDisplayContrastSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="200"
                                            StepFrequency="1"
                                            Header="Contrast"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDDisplaySaturationSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="200"
                                            StepFrequency="1"
                                            Header="Saturation"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDDisplayTemperatureSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4000" Maximum="10000"
                                            StepFrequency="100"
                                            Header="Color Temperature (K)"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- AMD Section Header -->
                        <TextBlock Text="AMD"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Radeon Super Resolution Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Super Resolution" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Upscales lower resolutions" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonSuperResolutionToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonSuperResolutionSharpnessSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonSuperResolutionToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Fluid Motion Frames Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Fluid Motion Frames" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Frame generation — global setting; AMD Adrenalin per-game profiles override this"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDFluidMotionFrameToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <!-- AFMF 2.x extended controls (ADLX 1.5+). Visible when AFMF is on,
                                     each ComboBox is enabled only when the v1 interface is live. -->
                                <ComboBox x:Name="AMDFluidMotionFrameAlgorithmComboBox"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Header="Algorithm"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Visibility="{x:Bind AMDFluidMotionFrameToggle.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                    <ComboBoxItem Content="Auto"/>
                                    <ComboBoxItem Content="Enhanced"/>
                                    <ComboBoxItem Content="Standard"/>
                                </ComboBox>
                                <ComboBox x:Name="AMDFluidMotionFrameSearchModeComboBox"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Header="Search mode"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Visibility="{x:Bind AMDFluidMotionFrameToggle.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                    <ComboBoxItem Content="Auto"/>
                                    <ComboBoxItem Content="Standard"/>
                                    <ComboBoxItem Content="High"/>
                                </ComboBox>
                                <ComboBox x:Name="AMDFluidMotionFramePerformanceModeComboBox"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Header="Performance mode"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Visibility="{x:Bind AMDFluidMotionFrameToggle.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                    <ComboBoxItem Content="Auto"/>
                                    <ComboBoxItem Content="Quality"/>
                                    <ComboBoxItem Content="Performance"/>
                                </ComboBox>
                                <ComboBox x:Name="AMDFluidMotionFrameFastMotionResponseComboBox"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Header="Fast motion response"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Visibility="{x:Bind AMDFluidMotionFrameToggle.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                    <ComboBoxItem Content="Repeat frames"/>
                                    <ComboBoxItem Content="Blended frames"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Anti-Lag Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Radeon Anti-Lag" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Reduces input latency" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDRadeonAntiLagToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- Radeon Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Boost" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Dynamic resolution scaling" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonBoostToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52" HorizontalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonBoostResolutionSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="1"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonBoostToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Radeon Chill Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Chill" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Power saving when idle" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonChillToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=AMDRadeonChillToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Slider x:Name="AMDRadeonChillMinFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            StepFrequency="1"
                                            SnapsTo="StepValues"
                                            Header="Min FPS"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDRadeonChillMaxFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            StepFrequency="1"
                                            SnapsTo="StepValues"
                                            Header="Max FPS"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Image Sharpening Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Image Sharpening" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Sharpen in-game visuals" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDImageSharpeningToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <Slider x:Name="AMDImageSharpeningSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDImageSharpeningToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </ScrollViewer>

                <!-- SYSTEM TAB -->
                <ScrollViewer x:Name="SystemScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- TDP Settings Card (Collapsible - consolidates Control Method, Device Limits, and Boost Settings) -->
                        <Border x:Name="TdpMethodCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Prerequisites" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Optional components GoTweaks Lite can install for you"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="TDPSettingsExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="TDPSettingsExpandButton_Click"
                                                  XYFocusUp="{x:Bind SystemNavItem}"
                                                  XYFocusDown="{x:Bind OSDCustomizeExpandButton}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="TDPSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="TDPSettingsContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- TDP Control Method Section — hidden: TDP is now governed only by the
                                         Performance tab (3 modes + Custom SPL/SPPT/FPPT). Method stays WMI on Legion.
                                         Kept in the tree (collapsed) so code-behind x:Name refs still resolve. -->
                                    <StackPanel x:Name="TdpControlMethodSection" Visibility="Collapsed">
                                    <TextBlock Text="Control Method" FontSize="13" FontWeight="SemiBold" Foreground="#B9C0CC" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock x:Name="TdpMethodDescription"
                                                       Text="PawnIO is anti-cheat safe and enables full OSD sensor support."
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ComboBox x:Name="TdpMethodComboBox"
                                                  Width="160"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  XYFocusUp="{x:Bind TDPSettingsExpandButton}"
                                                  XYFocusDown="{x:Bind InstallPawnIOButton}">
                                            <ComboBoxItem x:Name="TdpMethodWmiItem" Content="Manufacturer WMI" Tag="ManufacturerWMI" Visibility="Collapsed"/>
                                            <ComboBoxItem x:Name="TdpMethodPawnIOItem" Content="PawnIO" Tag="PawnIO"/>
                                            <ComboBoxItem x:Name="TdpMethodWinRing0Item" Content="WinRing0 (Legacy)" Tag="WinRing0"/>
                                        </ComboBox>
                                    </Grid>
                                    </StackPanel>

                                    <!-- PawnIO row -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="PawnIO Driver" FontSize="14" Foreground="White"/>
                                            <TextBlock Text="Signed kernel driver for extended sensors (fan speed, GPU power) and anti-cheat-safe TDP control"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="PawnIOStatusText"
                                                       Text="Not installed"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFC107"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="InstallPawnIOButton"
                                                Grid.Column="1"
                                                Content="Install"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="InstallPawnIOButton_Click"
                                                VerticalAlignment="Center"
                                                XYFocusUp="{x:Bind TDPSettingsExpandButton}"
                                                XYFocusDown="{x:Bind PrereqUsbipInstallButton}"/>
                                    </Grid>

                                    <Border Height="1" Background="#33FFFFFF" Margin="0,12,0,12"/>

                                    <!-- usbip-win2 row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="usbip-win2" FontSize="14" Foreground="White"/>
                                            <TextBlock Text="Kernel driver that powers VIIPER virtual controller emulation (native gyro, alternate pad types)"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="PrereqUsbipStatusText"
                                                       Text="Not installed"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFC107"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="PrereqUsbipInstallButton"
                                                Grid.Column="1"
                                                Content="Install"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="PrereqUsbipInstallButton_Click"
                                                VerticalAlignment="Center"
                                                XYFocusUp="{x:Bind InstallPawnIOButton}"
                                                XYFocusDown="{x:Bind PrereqHidHideInstallButton}"/>
                                    </Grid>

                                    <Border Height="1" Background="#33FFFFFF" Margin="0,12,0,12"/>

                                    <!-- HidHide row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="HidHide" FontSize="14" Foreground="White"/>
                                            <TextBlock Text="Hides the stock controller from games while emulation is active, so input isn't read twice"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="PrereqHidHideStatusText"
                                                       Text="Not installed"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFC107"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="PrereqHidHideInstallButton"
                                                Grid.Column="1"
                                                Content="Install"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="PrereqHidHideInstallButton_Click"
                                                VerticalAlignment="Center"
                                                XYFocusUp="{x:Bind PrereqUsbipInstallButton}"
                                                XYFocusDown="{x:Bind OSDCustomizeExpandButton}"/>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- OSD Customization Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="OSD Customization" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Customize overlay appearance and content"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="OSDCustomizeExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="OSDCustomizeExpandButton_Click"
                                                  XYFocusUp="{x:Bind TDPSettingsExpandButton}"
                                                  XYFocusDown="{x:Bind HotkeysExpandButton}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="OSDCustomizeExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="OSDCustomizeContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- OSD Provider Selection -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="OSD Provider"
                                                       Foreground="#FFFFFF"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                            <TextBlock Text="Select overlay source"
                                                       Foreground="#888888"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDProviderComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="120"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDProviderComboBox_SelectionChanged"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent">
                                            <ComboBoxItem Content="RTSS" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="AMD" Tag="1"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- RTSS-specific options (hidden when AMD provider is selected) -->
                                    <StackPanel x:Name="RTSSOptionsPanel">
                                        <!-- Overlay Level Selection -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Overlay Level"
                                                       Foreground="#FFFFFF"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                            <ComboBox x:Name="OSDCustomizeLevelComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      Width="120"
                                                      Grid.Column="1"
                                                      SelectionChanged="OSDCustomizeLevelComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White"
                                                      FocusVisualSecondaryBrush="Transparent">
                                                <ComboBoxItem Content="Basic" Tag="1" IsSelected="True"/>
                                                <ComboBoxItem Content="Detailed" Tag="2"/>
                                                <ComboBoxItem Content="Full" Tag="3"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Layout Settings Section -->
                                    <TextBlock Text="Layout"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,0,0,8"/>

                                    <!-- Columns -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Columns"
                                                       Foreground="#888888"
                                                       FontSize="13"/>
                                            <TextBlock Text="Items per row (1 = vertical list)"
                                                       Foreground="#888888"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDColumnsComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="80"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="1" Tag="1"/>
                                            <ComboBoxItem Content="2" Tag="2"/>
                                            <ComboBoxItem Content="3" Tag="3" IsSelected="True"/>
                                            <ComboBoxItem Content="4" Tag="4"/>
                                            <ComboBoxItem Content="5" Tag="5"/>
                                            <ComboBoxItem Content="6" Tag="6"/>
                                            <ComboBoxItem Content="7" Tag="7"/>
                                            <ComboBoxItem Content="8" Tag="8"/>
                                            <ComboBoxItem Content="9" Tag="9"/>
                                            <ComboBoxItem Content="10" Tag="10"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Text Size -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Text Size"
                                                   Foreground="#888888"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <ComboBox x:Name="OSDTextSizeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="100"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="Small" Tag="50"/>
                                            <ComboBoxItem Content="Medium" Tag="100" IsSelected="True"/>
                                            <ComboBoxItem Content="Large" Tag="150"/>
                                            <ComboBoxItem Content="X-Large" Tag="200"/>
                                            <ComboBoxItem Content="XX-Large" Tag="250"/>
                                            <ComboBoxItem Content="XXX-Large" Tag="300"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Colors Section -->
                                    <TextBlock Text="Colors"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,12,0,8"/>

                                    <!-- Text Color -->
                                    <StackPanel x:Name="OSDTextColorCard" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Text Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox x:Name="OSDTextColorDynamicCheckBox"
                                                          Content="Dynamic"
                                                          IsChecked="True"
                                                          Foreground="#B9C0CC"
                                                          FontSize="11"
                                                          Margin="0,0,8,0"
                                                          Checked="OSDTextColorDynamic_Changed"
                                                          Unchecked="OSDTextColorDynamic_Changed"/>
                                                <Border x:Name="OSDTextColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="White"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="OSDTextColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="OSDTextColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="OSDTextColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="White"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="OSDTextColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- Label Color (Global) -->
                                    <StackPanel x:Name="OSDLabelColorCard" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Label Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox x:Name="OSDLabelColorDefaultCheckBox"
                                                          Content="Default"
                                                          IsChecked="True"
                                                          Foreground="#B9C0CC"
                                                          FontSize="11"
                                                          Margin="0,0,8,0"
                                                          Checked="OSDLabelColorDefault_Changed"
                                                          Unchecked="OSDLabelColorDefault_Changed"/>
                                                <Border x:Name="OSDLabelColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="#00FFFF"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="OSDLabelColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="OSDLabelColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="OSDLabelColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="#00FFFF"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="OSDLabelColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- OSD Opacity Slider (for OLED protection) -->
                                    <StackPanel Margin="0,8,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="OSD Opacity" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13"/>
                                            <TextBlock x:Name="OSDOpacityValue"
                                                       Grid.Column="1"
                                                       Text="100%" FontSize="13" Foreground="#4CAF50"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="Reduce OSD brightness to protect OLED pixels" Foreground="#888888" FontSize="11" Margin="0,2,0,4"/>
                                        <Slider x:Name="OSDOpacitySlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="10" Maximum="100"
                                                TickFrequency="5"
                                                SnapsTo="Ticks"
                                                Value="100"
                                                ValueChanged="OSDOpacitySlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Position Shift Toggle (OLED burn-in protection) -->
                                    <Grid Margin="0,4,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Position Shift" Foreground="#B9C0CC" FontSize="13"/>
                                            <TextBlock Text="Shifts OSD every minute to prevent burn-in" Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="OSDPositionShiftToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="OSDPositionShiftToggle_Toggled"/>
                                    </Grid>

                                    <!-- Frametime Graph Pinned Toggle -->
                                    <Grid Margin="0,4,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Pin Frametime Graph" Foreground="#B9C0CC" FontSize="13"/>
                                            <TextBlock Text="Always display graph on its own row at bottom" Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="FrametimeGraphPinnedToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="FrametimeGraphPinnedToggle_Toggled"/>
                                    </Grid>

                                        <!-- Items Section -->
                                        <TextBlock Text="Items to Display"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,12,0,8"/>

                                        <!-- OSD Items with reordering -->
                                        <ItemsControl x:Name="OSDItemsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  Content="{Binding DisplayName}"
                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                  Foreground="#FFFFFF"
                                                                  Tag="{Binding Id}"
                                                                  UseSystemFocusVisuals="True"
                                                                  FocusVisualPrimaryBrush="White"
                                                                  FocusVisualSecondaryBrush="Transparent"
                                                                  Checked="OSDItemCheckBox_Changed"
                                                                  Unchecked="OSDItemCheckBox_Changed"/>

                                                        <Button Grid.Column="1"
                                                                Content="&#xE70E;"
                                                                FontFamily="Segoe MDL2 Assets"
                                                                FontSize="10"
                                                                Width="28" Height="24"
                                                                Padding="0"
                                                                Margin="4,0,0,0"
                                                                Background="Transparent"
                                                                Tag="{Binding Id}"
                                                                IsEnabled="{Binding CanMoveUp}"
                                                                Click="OSDItemMoveUp_Click"/>

                                                        <Button Grid.Column="2"
                                                                Content="&#xE70D;"
                                                                FontFamily="Segoe MDL2 Assets"
                                                                FontSize="10"
                                                                Width="28" Height="24"
                                                                Padding="0"
                                                                Margin="4,0,0,0"
                                                                Background="Transparent"
                                                                Tag="{Binding Id}"
                                                                IsEnabled="{Binding CanMoveDown}"
                                                                Click="OSDItemMoveDown_Click"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Custom RTSS Tags Section -->
                                        <TextBlock Text="Custom RTSS Tags"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,16,0,4"/>
                                        <TextBlock Text="Add custom RTSS tags (e.g. &lt;FR&gt; for FPS)"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   Margin="0,0,0,8"/>
                                        <TextBox x:Name="OSDCustomTagsTextBox"
                                                 PlaceholderText="Enter custom RTSS tags..."
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 Height="60"
                                                 TextChanged="OSDCustomTagsTextBox_TextChanged"/>
                                    </StackPanel>

                                    <!-- AMD-specific info (shown when AMD provider is selected) -->
                                    <StackPanel x:Name="AMDOptionsPanel" Visibility="Collapsed">
                                        <TextBlock Text="AMD Adrenaline Overlay"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="The AMD overlay is controlled through Adrenaline software. Use Ctrl+Shift+O to toggle and Ctrl+Shift+X to cycle overlay levels."
                                                   Foreground="#B9C0CC"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Hotkeys Card (Collapsible) - Xbox Controller Button Combos -->
                        <Border x:Name="HotkeysCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Hotkeys" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="HotkeysSummary"
                                                   Text="Map controller combos to keyboard shortcuts"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="HotkeysExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="HotkeysExpandButton_Click"
                                                  XYFocusUp="{x:Bind OSDCustomizeExpandButton}"
                                                  XYFocusDown="{x:Bind DebugExpandButton}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="HotkeysExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="HotkeysContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Menu+A Row -->
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="View + A" VerticalAlignment="Center" Foreground="#FFFFFF" FontSize="13"/>
                                            <ComboBox x:Name="HotkeyMenuAComboBox" Grid.Column="1"
                                                      SelectionChanged="HotkeyMenuA_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="Disabled" Tag="0"/>
                                                <ComboBoxItem Content="Keyboard Shortcut" Tag="1"/>
                                                <ComboBoxItem Content="Toggle OSD" Tag="3"/>
                                                <ComboBoxItem Content="Screenshot" Tag="4"/>
                                                <ComboBoxItem Content="Alt+Tab" Tag="5"/>
                                                <ComboBoxItem Content="Alt+F4" Tag="6"/>
                                                <ComboBoxItem Content="Open Keyboard" Tag="7"/>
                                                <ComboBoxItem Content="Task Manager" Tag="9"/>
                                                <ComboBoxItem Content="Focus GoTweaks Lite" Tag="10"/>
                                            </ComboBox>
                                        </Grid>
                                        <StackPanel x:Name="HotkeyMenuAKeyPanel" Orientation="Horizontal" Margin="80,4,0,0" Visibility="Collapsed">
                                            <ItemsControl x:Name="HotkeyMenuAKeyTags">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                            <ComboBox x:Name="HotkeyMenuAKeyComboBox" Width="90" Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectedIndex="0" SelectionChanged="HotkeyMenuAKey_SelectionChanged">
                                                <x:String>+ Key</x:String><x:String>A</x:String><x:String>B</x:String><x:String>C</x:String><x:String>D</x:String><x:String>E</x:String><x:String>F</x:String><x:String>G</x:String><x:String>H</x:String><x:String>I</x:String><x:String>J</x:String><x:String>K</x:String><x:String>L</x:String><x:String>M</x:String><x:String>N</x:String><x:String>O</x:String><x:String>P</x:String><x:String>Q</x:String><x:String>R</x:String><x:String>S</x:String><x:String>T</x:String><x:String>U</x:String><x:String>V</x:String><x:String>W</x:String><x:String>X</x:String><x:String>Y</x:String><x:String>Z</x:String><x:String>0</x:String><x:String>1</x:String><x:String>2</x:String><x:String>3</x:String><x:String>4</x:String><x:String>5</x:String><x:String>6</x:String><x:String>7</x:String><x:String>8</x:String><x:String>9</x:String><x:String>F1</x:String><x:String>F2</x:String><x:String>F3</x:String><x:String>F4</x:String><x:String>F5</x:String><x:String>F6</x:String><x:String>F7</x:String><x:String>F8</x:String><x:String>F9</x:String><x:String>F10</x:String><x:String>F11</x:String><x:String>F12</x:String><x:String>Enter</x:String><x:String>Esc</x:String><x:String>Space</x:String><x:String>Tab</x:String><x:String>Backspace</x:String><x:String>Up</x:String><x:String>Down</x:String><x:String>Left</x:String><x:String>Right</x:String><x:String>LCtrl</x:String><x:String>LShift</x:String><x:String>LAlt</x:String><x:String>LWin</x:String><x:String>RCtrl</x:String><x:String>RShift</x:String><x:String>RAlt</x:String><x:String>RWin</x:String><x:String>Home</x:String><x:String>End</x:String><x:String>PgUp</x:String><x:String>PgDn</x:String><x:String>Insert</x:String><x:String>Delete</x:String><x:String>PrintScr</x:String><x:String>Pause</x:String><x:String>VolUp</x:String><x:String>VolDown</x:String><x:String>VolMute</x:String><x:String>[</x:String><x:String>]</x:String>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Menu+B Row -->
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="View + B" VerticalAlignment="Center" Foreground="#FFFFFF" FontSize="13"/>
                                            <ComboBox x:Name="HotkeyMenuBComboBox" Grid.Column="1"
                                                      SelectionChanged="HotkeyMenuB_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="Disabled" Tag="0"/>
                                                <ComboBoxItem Content="Keyboard Shortcut" Tag="1"/>
                                                <ComboBoxItem Content="Toggle OSD" Tag="3"/>
                                                <ComboBoxItem Content="Screenshot" Tag="4"/>
                                                <ComboBoxItem Content="Alt+Tab" Tag="5"/>
                                                <ComboBoxItem Content="Alt+F4" Tag="6"/>
                                                <ComboBoxItem Content="Open Keyboard" Tag="7"/>
                                                <ComboBoxItem Content="Task Manager" Tag="9"/>
                                                <ComboBoxItem Content="Focus GoTweaks Lite" Tag="10"/>
                                            </ComboBox>
                                        </Grid>
                                        <StackPanel x:Name="HotkeyMenuBKeyPanel" Orientation="Horizontal" Margin="80,4,0,0" Visibility="Collapsed">
                                            <ItemsControl x:Name="HotkeyMenuBKeyTags">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                            <ComboBox x:Name="HotkeyMenuBKeyComboBox" Width="90" Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectedIndex="0" SelectionChanged="HotkeyMenuBKey_SelectionChanged">
                                                <x:String>+ Key</x:String><x:String>A</x:String><x:String>B</x:String><x:String>C</x:String><x:String>D</x:String><x:String>E</x:String><x:String>F</x:String><x:String>G</x:String><x:String>H</x:String><x:String>I</x:String><x:String>J</x:String><x:String>K</x:String><x:String>L</x:String><x:String>M</x:String><x:String>N</x:String><x:String>O</x:String><x:String>P</x:String><x:String>Q</x:String><x:String>R</x:String><x:String>S</x:String><x:String>T</x:String><x:String>U</x:String><x:String>V</x:String><x:String>W</x:String><x:String>X</x:String><x:String>Y</x:String><x:String>Z</x:String><x:String>0</x:String><x:String>1</x:String><x:String>2</x:String><x:String>3</x:String><x:String>4</x:String><x:String>5</x:String><x:String>6</x:String><x:String>7</x:String><x:String>8</x:String><x:String>9</x:String><x:String>F1</x:String><x:String>F2</x:String><x:String>F3</x:String><x:String>F4</x:String><x:String>F5</x:String><x:String>F6</x:String><x:String>F7</x:String><x:String>F8</x:String><x:String>F9</x:String><x:String>F10</x:String><x:String>F11</x:String><x:String>F12</x:String><x:String>Enter</x:String><x:String>Esc</x:String><x:String>Space</x:String><x:String>Tab</x:String><x:String>Backspace</x:String><x:String>Up</x:String><x:String>Down</x:String><x:String>Left</x:String><x:String>Right</x:String><x:String>LCtrl</x:String><x:String>LShift</x:String><x:String>LAlt</x:String><x:String>LWin</x:String><x:String>RCtrl</x:String><x:String>RShift</x:String><x:String>RAlt</x:String><x:String>RWin</x:String><x:String>Home</x:String><x:String>End</x:String><x:String>PgUp</x:String><x:String>PgDn</x:String><x:String>Insert</x:String><x:String>Delete</x:String><x:String>PrintScr</x:String><x:String>Pause</x:String><x:String>VolUp</x:String><x:String>VolDown</x:String><x:String>VolMute</x:String><x:String>[</x:String><x:String>]</x:String>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Menu+X Row -->
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="View + X" VerticalAlignment="Center" Foreground="#FFFFFF" FontSize="13"/>
                                            <ComboBox x:Name="HotkeyMenuXComboBox" Grid.Column="1"
