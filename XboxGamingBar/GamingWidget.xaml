                                <!-- Collapsible Content -->
                                <StackPanel x:Name="AboutContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Updates - everything update-related lives here, at the top. -->
                                    <Button x:Name="CheckForUpdateButton"
                                            Content="Check for Update"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource StandaloneButtonStyle}"
                                            Click="CheckForUpdateButton_Click"/>

                                    <!-- Update Status Text -->
                                    <TextBlock x:Name="UpdateStatusText"
                                               Text=""
                                               FontSize="12"
                                               Foreground="#B9C0CC"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Visibility="Collapsed"/>

                                    <!-- Update Button (shown when update available) -->
                                    <Button x:Name="UpdateButton"
                                            Content="Update"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource StandaloneButtonStyle}"
                                            Background="#107C10"
                                            Click="UpdateButton_Click"
                                            Visibility="Collapsed"/>

                                    <!-- Single "check for updates automatically" preference, gating both
                                         update surfaces (the helper's Quick-tab banner probe and the
                                         widget's own startup auto-check) so there is only one on-screen
                                         toggle instead of two near-duplicate ones. -->
                                    <CheckBox x:Name="GoTweaksUpdateOnStartCheckbox"
                                              Content="Check for updates automatically on start"
                                              IsChecked="True"
                                              FontSize="12"
                                              Foreground="#B9C0CC"
                                              Margin="0,0,0,0"
                                              Checked="GoTweaksUpdateOnStartCheckbox_Changed"
                                              Unchecked="GoTweaksUpdateOnStartCheckbox_Changed"/>
                                    <CheckBox x:Name="GoTweaksHideBannerCheckbox"
                                              Content="Hide GoTweaks Lite update banner on Quick tab"
                                              IsChecked="False"
                                              FontSize="12"
                                              Foreground="#B9C0CC"
                                              Margin="0,4,0,0"
                                              Checked="GoTweaksHideBannerCheckbox_Changed"
                                              Unchecked="GoTweaksHideBannerCheckbox_Changed"/>

                                    <Border Height="1" Background="#33FFFFFF" Margin="0,16,0,16"/>

                                    <!-- Version -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Version"
                                                   FontSize="13"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AboutVersionText"
                                                   Text="0.3.98.0"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Fork Author -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Fork Author"
                                                   FontSize="13"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Rayek"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Original Author -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Original Author"
                                                   FontSize="13"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="LtChipotle"
                                                   FontSize="14"
                                                   Foreground="#B9C0CC"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Special Thanks -->
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Special Thanks"
                                                   FontSize="13"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Mute, GameTechPlanet"
                                                   FontSize="14"
                                                   Foreground="#888888"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SCALING TAB -->
                <ScrollViewer x:Name="ScalingScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Lossless Scaling Status" Style="{StaticResource CardTitleStyle}" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="ShowLosslessScalingWindowButton"
                                            Grid.Column="1"
                                            Content="Show Window"
                                            Margin="0,0,8,0"
                                            Visibility="Collapsed"
                                            Click="ShowLosslessScalingWindowButton_Click"
                                            XYFocusUp="{x:Bind ScalingNavItem}"/>
                                    <Button x:Name="LaunchLosslessScalingButton"
                                            Grid.Column="2"
                                            Content="Launch"
                                            Visibility="Collapsed"
                                            Click="LaunchLosslessScalingButton_Click"
                                            XYFocusUp="{x:Bind ScalingNavItem}"/>
                                </Grid>
                                <TextBlock x:Name="LosslessScalingStatusText"
                                           Text="Not Installed"
                                           Style="{StaticResource CardCaptionStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Current Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Profile" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="LosslessScalingCurrentProfileText"
                                                   Text="Default"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource SystemAccentBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="LosslessScalingCreateProfileButton"
                                            Grid.Column="1"
                                            Content="Create Profile"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Click="LosslessScalingCreateProfileButton_Click"
                                            XYFocusUp="{x:Bind ScalingNavItem}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Scale Toggle Button -->
                        <ToggleButton x:Name="LosslessScalingEnabledToggle"
                                      Content="Scale"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="False"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource ScaleToggleButtonStyle}"/>

                        <!-- Apply and Restart Button -->
                        <Button x:Name="LosslessScalingSaveSettingsButton"
                                Content="Apply and Restart"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                IsEnabled="False"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="LosslessScalingSaveSettingsButton_Click"/>

                        <!-- Reset Profile Button -->
                        <Button x:Name="LosslessScalingResetProfileButton"
                                Content="Reset to Defaults"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                IsEnabled="False"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="LosslessScalingResetProfileButton_Click"/>

                        <!-- AutoScale Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="AutoScale" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically detect and scale games"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingAutoScaleToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=LosslessScalingAutoScaleToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="AutoScale Delay (s)"
                                                   FontSize="13"
                                                   Foreground="#B9C0CC"/>
                                        <TextBlock x:Name="LosslessScalingAutoScaleDelayValueText"
                                                   Text="{Binding ElementName=LosslessScalingAutoScaleDelaySlider, Path=Value}"
                                                   FontSize="13"
                                                   Foreground="#B9C0CC"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingAutoScaleDelaySlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="10"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scaling Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scaling Algorithm" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScalingTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScalingTypeComboBox_SelectionChanged">
                                    <x:String>Off</x:String>
                                    <x:String>LS1</x:String>
                                    <x:String>FSR</x:String>
                                    <x:String>NIS</x:String>
                                    <x:String>SGSR</x:String>
                                    <x:String>BCAS</x:String>
                                    <x:String>Anime4K</x:String>
                                    <x:String>xBR</x:String>
                                    <x:String>Sharp Bilinear</x:String>
                                    <x:String>Integer</x:String>
                                    <x:String>Nearest Neighbor</x:String>
                                </ComboBox>

                                <!-- Sharpness Slider (for FSR, NIS, SGSR, BCAS) -->
                                <StackPanel x:Name="LosslessScalingSharpnessPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Sharpness" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock x:Name="LosslessScalingSharpnessValueText"
                                                   Text="{Binding ElementName=LosslessScalingSharpnessSlider, Path=Value}"
                                                   FontSize="13"
                                                   Foreground="#B9C0CC"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingSharpnessSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>

                                <!-- FSR Optimize Toggle (FSR only) -->
                                <Grid x:Name="LosslessScalingFSROptimizePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Optimize" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                    <ToggleSwitch x:Name="LosslessScalingFSROptimizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- LS1 Type (LS1 only) — BALANCED vs PERFORMANCE -->
                                <StackPanel x:Name="LosslessScalingLS1TypePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="LS1 Type" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingLS1TypeComboBox"
                                              PlaceholderText="Select Type"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>BALANCED</x:String>
                                        <x:String>PERFORMANCE</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Resize Before Scale (any non-Off scaling type) -->
                                <Grid x:Name="LosslessScalingResizeBeforePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Resize Before Scale" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Snap window to integer ratio before upscale"
                                                   FontSize="11" Foreground="#888888"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingResizeBeforeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- Anime4K Settings -->
                                <StackPanel x:Name="LosslessScalingAnime4KPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Size" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAnime4KSizeComboBox"
                                              PlaceholderText="Select Size"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Small</x:String>
                                        <x:String>Medium</x:String>
                                        <x:String>Large</x:String>
                                        <x:String>Very Large</x:String>
                                        <x:String>Ultra Large</x:String>
                                    </ComboBox>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="VRS" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="LosslessScalingAnime4KVRSToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scale Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scale Mode" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScaleModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScaleModeComboBox_SelectionChanged">
                                    <x:String>Auto</x:String>
                                    <x:String>Custom</x:String>
                                </ComboBox>

                                <!-- Auto Mode Settings -->
                                <StackPanel x:Name="LosslessScalingAutoModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Aspect" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAspectRatioComboBox"
                                              PlaceholderText="Select Aspect"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Aspect Ratio</x:String>
                                        <x:String>Fullscreen</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Custom Mode Settings -->
                                <StackPanel x:Name="LosslessScalingCustomModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Scale Factor" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock x:Name="LosslessScalingScaleFactorValueText"
                                                   Text="{Binding ElementName=LosslessScalingScaleFactorSlider, Path=Value}"
                                                   FontSize="13"
                                                   Foreground="#B9C0CC"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingScaleFactorSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="5"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Frame Generation Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Frame Generation" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingFrameGenTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>Off</x:String>
                                    <x:String>LSFG1</x:String>
                                    <x:String>LSFG2</x:String>
                                    <x:String>LSFG3</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- LSFG3 Settings Card -->
                        <Border x:Name="LSFG3SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG3 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG3 Mode -->
                                <TextBlock Text="Mode" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG3ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12"
                                          SelectionChanged="LosslessScalingLSFG3ModeComboBox_SelectionChanged">
                                    <x:String>FIXED</x:String>
                                    <x:String>ADAPTIVE</x:String>
                                </ComboBox>

                                <!-- LSFG3 Multiplier (hidden when Adaptive) -->
                                <StackPanel x:Name="LosslessScalingLSFG3MultiplierPanel">
                                    <TextBlock Text="Multiplier" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingLSFG3MultiplierComboBox"
                                              PlaceholderText="Select Multiplier"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Margin="0,0,0,12">
                                        <x:String>2</x:String>
                                        <x:String>3</x:String>
                                        <x:String>4</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- LSFG3 Target FPS -->
                                <Grid>
                                    <TextBlock Text="Target FPS" FontSize="13" Foreground="#FFFFFF"/>
                                    <TextBlock x:Name="LosslessScalingLSFG3TargetValueText"
                                               Text="{Binding ElementName=LosslessScalingLSFG3TargetSlider, Path=Value}"
                                               FontSize="13"
                                               Foreground="#B9C0CC"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingLSFG3TargetSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="30" Maximum="240"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Flow Scale -->
                                <Grid>
                                    <TextBlock Text="Flow Scale" FontSize="13" Foreground="#FFFFFF"/>
                                    <TextBlock x:Name="LosslessScalingFlowScaleValueText"
                                               Text="{Binding ElementName=LosslessScalingFlowScaleSlider, Path=Value}"
                                               FontSize="13"
                                               Foreground="#B9C0CC"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingFlowScaleSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="25" Maximum="100"
                                        TickFrequency="5"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Size Toggle (Performance/Balanced) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Performance Mode" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Lighter model for less input lag"
                                                   FontSize="11"
                                                   Foreground="#B9C0CC"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingSizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LSFG2 Settings Card -->
                        <Border x:Name="LSFG2SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG2 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG2 Mode -->
                                <TextBlock Text="Mode" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG2ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>X2</x:String>
                                    <x:String>X3</x:String>
                                    <x:String>X4</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Sync & Display Card (added 2026-05-01) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Sync &amp; Display" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- Sync Mode -->
                                <TextBlock Text="Sync Mode" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingSyncModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12">
                                    <x:String>OFF</x:String>
                                    <x:String>DEFAULT</x:String>
                                    <x:String>VSYNC1</x:String>
                                    <x:String>VSYNC2</x:String>
                                    <x:String>VSYNC3</x:String>
                                    <x:String>VSYNC4</x:String>
                                </ComboBox>

                                <!-- Max Frame Latency -->
                                <Grid>
                                    <TextBlock Text="Max Frame Latency" FontSize="13" Foreground="#FFFFFF"/>
                                    <TextBlock x:Name="LosslessScalingMaxFrameLatencyValueText"
                                               Text="{Binding ElementName=LosslessScalingMaxFrameLatencySlider, Path=Value}"
                                               FontSize="13"
                                               Foreground="#B9C0CC"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingMaxFrameLatencySlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="4"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- HDR Support -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="HDR Support" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Preserve HDR through scaling/FG"
                                                   FontSize="11" Foreground="#B9C0CC"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingHdrSupportToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- G-Sync Support -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="G-Sync / VRR Support" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Improves pacing on VRR displays"
                                                   FontSize="11" Foreground="#B9C0CC"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingGsyncSupportToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Capture & Overlay Card (added 2026-05-01) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Capture &amp; Overlay" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- Capture API -->
                                <TextBlock Text="Capture API" FontSize="13" Foreground="#FFFFFF" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingCaptureApiComboBox"
                                          PlaceholderText="Select API"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12">
                                    <x:String>DXGI</x:String>
                                    <x:String>WGC</x:String>
                                    <x:String>GDI</x:String>
                                </ComboBox>
                                <TextBlock Text="WGC = best compat, DXGI = lower latency, GDI = legacy"
                                           FontSize="11" Foreground="#888888" Margin="0,0,0,8"/>

                                <!-- Draw FPS overlay -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Draw FPS Overlay" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="LS draws fps counter on top-left of scaled output"
                                                   FontSize="11" Foreground="#B9C0CC"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingDrawFpsToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Conflict Warning Card -->
                        <Border Style="{StaticResource CardStyle}" x:Name="LSConflictWarningBorder" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Conflict Detected"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#FFA500"/>
                                <TextBlock x:Name="LSConflictWarningText"
                                           Text="AMD Fluid Motion Frames has been automatically disabled because it conflicts with Lossless Scaling Frame Generation."
                                           FontSize="13"
                                           Foreground="#FFA500"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- LEGION TAB -->
                <ScrollViewer x:Name="LegionScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Controller Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="LegionDeviceNameText" Text="Legion Go Controller" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="LegionControllerStatusText"
                                           Text="Connected"
                                           FontSize="14"
                                           Foreground="#4CAF50"
                                           Margin="0,4,0,0"/>

                                <!-- Separator under the title -->
                                <Border Height="1" Background="#33FFFFFF" Margin="0,10,0,0"/>

                                <!-- Controller Battery Info (hidden on devices without detachable controllers) -->
                                <StackPanel x:Name="ControllerBatterySection">
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Controller -->
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Left Controller" FontSize="12" Foreground="#B9C0CC" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <FontIcon Glyph="&#xE83F;" FontSize="14" Foreground="#B9C0CC" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="LeftControllerBatteryText"
                                                           Text="--%"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"/>
                                                <FontIcon x:Name="LeftControllerChargingIcon"
                                                          Glyph="&#xE945;"
                                                          FontSize="12"
                                                          Foreground="#4CAF50"
                                                          Margin="6,0,0,0"
                                                          Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock x:Name="LeftControllerConnectionText"
                                                       Text="--"
                                                       FontSize="11"
                                                       Foreground="#888888"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Right Controller -->
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Right Controller" FontSize="12" Foreground="#B9C0CC" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <FontIcon Glyph="&#xE83F;" FontSize="14" Foreground="#B9C0CC" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="RightControllerBatteryText"
                                                           Text="--%"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"/>
                                                <FontIcon x:Name="RightControllerChargingIcon"
                                                          Glyph="&#xE945;"
                                                          FontSize="12"
                                                          Foreground="#4CAF50"
                                                          Margin="6,0,0,0"
                                                          Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock x:Name="RightControllerConnectionText"
                                                       Text="--"
                                                       FontSize="11"
                                                       Foreground="#888888"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Device Info -->
                                <TextBlock x:Name="LegionControllerPidVidText"
                                           Text="VID:PID --"
                                           FontSize="11"
                                           Foreground="#888888"
                                           Margin="0,8,0,0"/>

                                <!-- Controller Information (populated from b0:01 device status) -->
                                <StackPanel x:Name="LegionControllerInfoSection" Visibility="Collapsed" Margin="0,10,0,0">
                                    <TextBlock Text="Controller Information"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#B9C0CC"
                                               Margin="0,0,0,6"/>

                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Firmware" FontSize="12" Foreground="#B9C0CC"/>
                                        <TextBlock Grid.Column="1" x:Name="LegionControllerFirmwareText"
                                                   Text="—" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Stick light" FontSize="12" Foreground="#B9C0CC"/>
                                        <TextBlock Grid.Column="1" x:Name="LegionControllerLightText"
                                                   Text="—" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF"
                                                   HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                        <Border Grid.Column="2" x:Name="LegionControllerLightSwatch"
                                                Width="14" Height="14" CornerRadius="3"
                                                BorderThickness="1" BorderBrush="#444444"
                                                Visibility="Collapsed"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Vibration" FontSize="12" Foreground="#B9C0CC"/>
                                        <TextBlock Grid.Column="1" x:Name="LegionControllerVibrationText"
                                                   Text="—" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Touchpad" FontSize="12" Foreground="#B9C0CC"/>
                                        <TextBlock Grid.Column="1" x:Name="LegionControllerTouchpadText"
                                                   Text="—" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Controller auto-sleep (idle power-off) timeout -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Controller sleep" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13"/>
                                        <ComboBox x:Name="LegionControllerSleepComboBox" Grid.Column="1" Width="110"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="3"
                                                  SelectionChanged="LegionControllerSleepComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Never" Tag="0"/>
                                            <ComboBoxItem Content="5 min" Tag="5"/>
                                            <ComboBoxItem Content="10 min" Tag="10"/>
                                            <ComboBoxItem Content="15 min" Tag="15"/>
                                            <ComboBoxItem Content="20 min" Tag="20"/>
                                            <ComboBoxItem Content="30 min" Tag="30"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Touchpad & Vibration Card (hidden on devices without HID touchpad support) -->
                        <StackPanel x:Name="TouchpadVibrationSection">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Touchpad &amp; Vibration" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Touchpad and haptic feedback settings"
                                                       Style="{StaticResource CardCaptionStyle}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="TouchpadVibrationExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="TouchpadVibrationExpandToggle_Click"
                                                  XYFocusUp="{x:Bind LegionNavItem}">
                                        <FontIcon x:Name="TouchpadVibrationExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="TouchpadVibrationContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Touchpad Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Touchpad Enabled" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="14"/>
                                        <ToggleSwitch x:Name="LegionTouchpadToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="True"
                                                      XYFocusUp="{x:Bind LegionNavItem}"
                                                      XYFocusDown="{x:Bind LegionVibrationComboBox}"/>
                                    </Grid>

                                    <!-- Vibration Intensity -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Vibration Intensity" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="14"/>
                                        <ComboBox x:Name="LegionVibrationComboBox"
                                                  Grid.Column="1"
                                                  Width="100"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectedIndex="2">
                                            <x:String>Off</x:String>
                                            <x:String>Weak</x:String>
                                            <x:String>Medium</x:String>
                                            <x:String>Strong</x:String>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Vibration Mode -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Vibration Mode" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="14"/>
                                        <ComboBox x:Name="LegionVibrationModeComboBox"
                                                  Grid.Column="1"
                                                  Width="100"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectedIndex="0">
                                            <x:String>FPS</x:String>
                                            <x:String>Racing</x:String>
                                            <x:String>AVG</x:String>
                                            <x:String>SPG</x:String>
                                            <x:String>RPG</x:String>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Touchpad Haptics Dropdown -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Touchpad Haptics" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="14"/>
                                        <ComboBox x:Name="LegionTouchpadVibrationComboBox"
                                                  Grid.Column="1"
                                                  SelectedIndex="2"
                                                  Width="100"
                                                  Style="{StaticResource ModernComboBoxStyle}">
                                            <x:String>Off</x:String>
                                            <x:String>Low</x:String>
                                            <x:String>Medium</x:String>
                                            <x:String>High</x:String>
                                        </ComboBox>
                                    </Grid>

                                    <!-- GoTweaks Haptics: standalone per-button LRA clicks (works outside emulation) -->
                                    <Border Height="1" Background="#22FFFFFF" Margin="0,4,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="GoTweaks Haptics" Foreground="#FFFFFF" FontSize="13"/>
                                            <TextBlock Text="Tactile click on inputs, system-wide via the controller motors"
                                                       Foreground="#888888" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="GoTweaksHapticsMasterToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"
                                                      Toggled="GoTweaksHaptics_Changed"/>
                                    </Grid>

                                    <StackPanel x:Name="GoTweaksHapticsGroupsPanel" Spacing="10" Margin="0,4,0,0" Visibility="Collapsed">
                                        <!-- Pulse length (tap duration) -->
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="Pulse Length" FontSize="13" Foreground="#B9C0CC"/>
                                                <TextBlock x:Name="GoTweaksHapticsPulseValue" Text="10 ms" Style="{StaticResource CardValueStyle}"/>
                                            </Grid>
                                            <Slider x:Name="GoTweaksHapticsPulseSlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="4" Maximum="40" Value="10"
                                                    StepFrequency="1"
                                                    ValueChanged="GoTweaksHaptics_Changed"/>
                                        </StackPanel>
                                        <!-- Also click on release -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Click on release too" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13"/>
                                            <ToggleSwitch x:Name="GoTweaksHapticsReleaseToggle" Grid.Column="1" MinWidth="0"
                                                          Style="{StaticResource ModernToggleStyle}" IsOn="False" Toggled="GoTweaksHaptics_Changed"/>
                                        </Grid>
                                        <!-- ABXY -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleSwitch x:Name="GoTweaksHapticsFaceToggle" Grid.Column="0" MinWidth="0"
                                                          Style="{StaticResource ModernToggleStyle}" IsOn="True" Toggled="GoTweaksHaptics_Changed"/>
                                            <TextBlock Grid.Column="1" Text="ABXY buttons" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13" Margin="8,0,0,0"/>
                                            <Slider x:Name="GoTweaksHapticsFaceSlider" Grid.Column="2" Width="110" Minimum="0" Maximum="100" Value="100"
                                                    StepFrequency="5" VerticalAlignment="Center" ValueChanged="GoTweaksHaptics_Changed"/>
                                        </Grid>
                                        <!-- Front -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleSwitch x:Name="GoTweaksHapticsFrontToggle" Grid.Column="0" MinWidth="0"
                                                          Style="{StaticResource ModernToggleStyle}" IsOn="True" Toggled="GoTweaksHaptics_Changed"/>
                                            <TextBlock Grid.Column="1" Text="Front buttons (d-pad, start, bumpers)" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13" Margin="8,0,0,0"/>
                                            <Slider x:Name="GoTweaksHapticsFrontSlider" Grid.Column="2" Width="110" Minimum="0" Maximum="100" Value="100"
                                                    StepFrequency="5" VerticalAlignment="Center" ValueChanged="GoTweaksHaptics_Changed"/>
                                        </Grid>
                                        <!-- Back -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleSwitch x:Name="GoTweaksHapticsBackToggle" Grid.Column="0" MinWidth="0"
                                                          Style="{StaticResource ModernToggleStyle}" IsOn="True" Toggled="GoTweaksHaptics_Changed"/>
                                            <TextBlock Grid.Column="1" Text="Back buttons / paddles" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13" Margin="8,0,0,0"/>
                                            <Slider x:Name="GoTweaksHapticsBackSlider" Grid.Column="2" Width="110" Minimum="0" Maximum="100" Value="100"
                                                    StepFrequency="5" VerticalAlignment="Center" ValueChanged="GoTweaksHaptics_Changed"/>
                                        </Grid>
                                        <!-- Triggers -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleSwitch x:Name="GoTweaksHapticsTriggerToggle" Grid.Column="0" MinWidth="0"
                                                          Style="{StaticResource ModernToggleStyle}" IsOn="True" Toggled="GoTweaksHaptics_Changed"/>
                                            <TextBlock Grid.Column="1" Text="Triggers (LT / RT)" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13" Margin="8,0,0,0"/>
                                            <Slider x:Name="GoTweaksHapticsTriggerSlider" Grid.Column="2" Width="110" Minimum="0" Maximum="100" Value="100"
                                                    StepFrequency="5" VerticalAlignment="Center" ValueChanged="GoTweaksHaptics_Changed"/>
                                        </Grid>
                                    </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Lighting Section (hidden on devices without HID RGB lighting support) -->
                        <StackPanel x:Name="LightingSection">
                        <!-- Lighting Section Header -->
                        <TextBlock Text="Lighting" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Lighting Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Lighting" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Controller RGB and power button lighting"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="LightingExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="LightingExpandToggle_Click">
                                        <FontIcon x:Name="LightingExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="LightingContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Light Mode -->
                                    <StackPanel>
                                        <TextBlock Text="Light Mode" FontSize="13" Foreground="#B9C0CC" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="LegionLightModeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedIndex="1"
                                                  SelectionChanged="LegionLightModeComboBox_SelectionChanged">
                                            <x:String>Off</x:String>
                                            <x:String>Solid</x:String>
                                            <x:String>Pulse</x:String>
                                            <x:String>Dynamic</x:String>
                                            <x:String>Spiral</x:String>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Light Color (Solid, Pulse only) -->
                                    <StackPanel x:Name="LegionColorCard">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Light Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border x:Name="LegionColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="White"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="LegionColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="LegionColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="LegionColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="White"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="LegionColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- Brightness (all modes except Off) -->
                                    <StackPanel x:Name="LegionBrightnessCard">
                                        <Grid>
                                            <TextBlock Text="Brightness" FontSize="13" Foreground="#B9C0CC"/>
                                            <TextBlock x:Name="LegionBrightnessValue"
                                                       Text="100%"
                                                       Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="LegionBrightnessSlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="0" Maximum="100"
                                                Value="100"
                                                ValueChanged="LegionBrightnessSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Speed (Pulse, Dynamic, Spiral only) -->
                                    <StackPanel x:Name="LegionSpeedCard" Visibility="Collapsed">
                                        <Grid>
                                            <TextBlock Text="Speed" FontSize="13" Foreground="#B9C0CC"/>
                                            <TextBlock x:Name="LegionSpeedValue"
                                                       Text="50%"
                                                       Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="LegionSpeedSlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="0" Maximum="100"
                                                Value="50"
                                                ValueChanged="LegionSpeedSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Power Light Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Power Light" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="14"/>
                                        <ToggleSwitch x:Name="LegionPowerLightToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="True"/>
                                    </Grid>

                                    <!-- GoTweaks reactive lighting (input-driven; layers on top of the static mode above) -->
                                    <Border Height="1" Background="#22FFFFFF" Margin="0,4,0,4"/>
                                    <StackPanel>
                                        <TextBlock Text="Reactive Effect" FontSize="13" Foreground="#B9C0CC" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="GoTweaksReactiveModeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedIndex="0"
                                                  SelectionChanged="GoTweaksReactive_Changed">
                                            <ComboBoxItem Content="Off" Tag="disabled"/>
                                            <ComboBoxItem Content="Flash on press" Tag="flash"/>
                                            <ComboBoxItem Content="Cycle palette" Tag="cycle"/>
                                            <ComboBoxItem Content="Per-button color" Tag="perbutton"/>
                                            <ComboBoxItem Content="Hue advance on press" Tag="hue"/>
                                            <ComboBoxItem Content="Trigger pressure" Tag="trigger"/>
                                            <ComboBoxItem Content="Battery indicator" Tag="battery"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Flash color (Flash on press only) -->
                                    <StackPanel x:Name="GoTweaksReactiveFlashColorCard">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Flash Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#B9C0CC" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border x:Name="GoTweaksReactiveFlashPreview"
                                                        Width="24" Height="24" CornerRadius="4"
                                                        Background="White" BorderBrush="#50555C" BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="GoTweaksReactiveFlashExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets" FontSize="12" Padding="8,4"
                                                        Background="Transparent"
                                                        Click="GoTweaksReactiveFlashExpandButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="GoTweaksReactiveFlashColorPicker"
                                                     Visibility="Collapsed" Margin="0,12,0,0" Color="White"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
