                                                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                                    <TextBlock Text="100" FontSize="10" Foreground="#888888" VerticalAlignment="Top"/>
                                                    <TextBlock Text="75" FontSize="10" Foreground="#888888" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="50" FontSize="10" Foreground="#888888" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="25" FontSize="10" Foreground="#888888" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="0" FontSize="10" Foreground="#888888" VerticalAlignment="Bottom"/>
                                                </StackPanel>

