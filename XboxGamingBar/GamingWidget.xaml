                                                   TextWrapping="Wrap" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <!-- Per-mode VIEW selector — the dropdown picks which mode's saved
                                         curve and unlock state are being edited. It does NOT change the
                                         running power mode. When the active power mode changes externally
                                         (Lenovo button / TDP card), JumpFanCurveDropdownToActiveMode jumps
                                         the dropdown to follow. Items mirror TdpMode: Quiet=1, Balanced=2,
                                         Performance=3, Custom=255. -->
                                    <ComboBox x:Name="FanCurvePresetComboBox"
                                              Grid.Column="1"
                                              Width="120"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              ToolTipService.ToolTip="Pick which power mode's fan curve to view and edit. This does NOT change the running mode — switch modes from the Performance tab (TDP Mode)."
                                              SelectionChanged="FanCurvePresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Quiet"       Tag="1"/>
                                        <ComboBoxItem Content="Balanced"    Tag="2" IsSelected="True"/>
                                        <ComboBoxItem Content="Performance" Tag="3"/>
                                        <ComboBoxItem Content="Custom"      Tag="255"/>
                                    </ComboBox>
                                    <ToggleButton x:Name="FanCurveExpandToggle"
                                                  Grid.Column="2"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="FanCurveExpandToggle_Click">
                                        <FontIcon x:Name="FanCurveExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Helper-disconnected warning. Shown only when the pipe drops while
                                     the active mode had EC override on, since that's the case where
                                     0xC6C8 may still hold our last-written RPM with no one driving
                                     the loop. Cleared automatically when the pipe reconnects. -->
                                <Border x:Name="FanCurveHelperDisconnectedWarning"
                                        Background="#3D2A1A" CornerRadius="4" Padding="10" Margin="0,8,0,0"
                                        Visibility="Collapsed">
                                    <TextBlock Foreground="#FFB060" FontSize="11" TextWrapping="Wrap"
                                               Text="⚠ Helper disconnected with EC override active. Fan may be stuck at the last RPM until the helper reconnects, or reboot to clear."/>
                                </Border>

                                <!-- Unlock toggle row stays visible at all times. -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Unlock Fan Curve Override" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Bypass firmware minimums via direct EC write (per-mode)"
                                                   FontSize="11" Foreground="#B9C0CC" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LegionUnlockFanCurveToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsOn="False"
                                                  Toggled="LegionUnlockFanCurveToggle_Toggled"/>
                                </Grid>

                                <!-- Info / warning collapsed by default to keep the card tidy. Contains
                                     the safety warning, behavioral explainer, and credit for the EC
                                     override approach (Rodpad's LeGo2-Fan-Control). -->
                                <muxc:Expander x:Name="FanCurveInfoExpander"
                                               Margin="0,8,0,0"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch"
                                               IsExpanded="False">
                                    <muxc:Expander.Header>
                                        <TextBlock Text="Info &amp; safety notes" FontSize="12" Foreground="#B9C0CC"/>
                                    </muxc:Expander.Header>
                                    <StackPanel>
                                        <Border Background="#3D2A1A" CornerRadius="4" Padding="10"
                                                x:Name="UnlockFanCurveWarningBorder">
                                            <StackPanel>
                                                <TextBlock Foreground="#FFB060" FontWeight="SemiBold" FontSize="12">
                                                    ⚠ Aggressive curves can damage hardware
                                                </TextBlock>
                                                <TextBlock Foreground="#DDB890" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           Text="• Never 0% above ~50°C&#x0a;• 101°C software failsafe forces max RPM"/>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,8,0,0"
                                                   Text="• Curves &amp; unlock state save per power mode&#x0a;• Dropdown selects which mode to edit, not the active one&#x0a;• Unlock OFF: firmware drives the fan (Custom only via WMI, with firmware-enforced floors)&#x0a;• Unlock ON: helper writes the curve directly to EC every 3s, in any mode&#x0a;• Axis labels (10°C–100°C) are how the curve is stored; firmware modes may map temps differently"/>

                                        <TextBlock FontSize="10" Foreground="#888888" TextWrapping="Wrap" Margin="0,8,0,0">
                                            Credits:
                                            <Hyperlink NavigateUri="https://github.com/Rodpad/LeGo2-Fan-Control">Rodpad/LeGo2-Fan-Control</Hyperlink>
                                            ·
                                            <Hyperlink NavigateUri="https://github.com/Undervoltologist/legiongo2_ec_reverse_engineer">Undervoltologist EC RE</Hyperlink>
                                            ·
                                            <Hyperlink NavigateUri="https://github.com/namazso/PawnIO.Modules">namazso/PawnIO.Modules</Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </muxc:Expander>

                                <!-- Expandable graph content -->
                                <StackPanel x:Name="FanCurveContent" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Y-axis label -->
                                    <TextBlock Text="Fan %" FontSize="11" Foreground="#888888" Margin="0,0,0,4"/>

                                    <!-- Graph area -->
                                    <Grid Height="150">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Y-axis labels (percentage scale) -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                            <TextBlock Text="100" FontSize="10" Foreground="#888888" VerticalAlignment="Top"/>
                                            <TextBlock Text="75" FontSize="10" Foreground="#888888" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="50" FontSize="10" Foreground="#888888" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="25" FontSize="10" Foreground="#888888" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="0" FontSize="10" Foreground="#888888" VerticalAlignment="Bottom"/>
                                        </StackPanel>

                                        <!-- Canvas for drawing the graph -->
                                        <Canvas x:Name="FanCurveCanvas"
                                                Grid.Column="1"
                                                Background="#1A1A1A"
                                                PointerPressed="FanCurveCanvas_PointerPressed"
                                                PointerMoved="FanCurveCanvas_PointerMoved"
                                                PointerReleased="FanCurveCanvas_PointerReleased"
                                                PointerCaptureLost="FanCurveCanvas_PointerReleased"
                                                SizeChanged="FanCurveCanvas_SizeChanged">
                                            <!-- Grid lines drawn in code-behind -->

                                            <!-- Fill under the curve -->
                                            <Polygon x:Name="FanCurveFill"
                                                     Fill="#3300AAFF"
                                                     Stroke="Transparent"/>

                                            <!-- EC Override Floor Line (dashed orange reference line) -->
                                            <Polyline x:Name="ECFloorPolyline"
                                                      Stroke="#FF6600"
                                                      StrokeThickness="1.5"
                                                      StrokeDashArray="4,2"
                                                      Opacity="0.7"/>

                                            <!-- The curve line -->
                                            <Polyline x:Name="FanCurvePolyline"
                                                      Stroke="#00AAFF"
                                                      StrokeThickness="2"
                                                      StrokeLineJoin="Round"/>

                                            <!-- Temperature indicator line (vertical dashed line) - on top of curve -->
                                            <Line x:Name="TempIndicatorLine"
                                                  Y1="0" Y2="150"
                                                  Stroke="#FF8800"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="4,2"
                                                  Visibility="Collapsed"/>

                                            <!-- RPM indicator line (horizontal dashed line) - on top of curve -->
                                            <Line x:Name="RPMIndicatorLine"
                                                  X1="0" X2="300"
                                                  Stroke="#00FF88"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="4,2"
                                                  Visibility="Collapsed"/>

                                            <!-- Control points are created in code-behind -->
                                        </Canvas>
                                    </Grid>

                                    <!-- X-axis labels — one per curve breakpoint. Visible in both
                                         locked and unlocked states; the breakpoints are how the
                                         curve is stored regardless of which path applies it.
                                         Under the firmware (locked) path Lenovo's mapping from
                                         sensor temp to curve point may not be 1:1 with these
                                         labels — the Info expander notes that — but hiding the
                                         labels entirely was worse: users had no temp reference
                                         at all when editing a non-EC-override curve. -->
                                    <Grid x:Name="FanCurveTempAxisGrid" Margin="30,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="10°C" FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="20"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="2" Text="30"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="3" Text="40"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="4" Text="50"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="5" Text="60"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="6" Text="70"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="7" Text="80"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="8" Text="90"   FontSize="9"  Foreground="#888888" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="8" Text="100°C" FontSize="9" Foreground="#888888" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Legacy locked-state hint, retained as collapsed shim so
                                         the code-behind reference (FanCurveLockedAxisHint) still
                                         resolves. The temp axis grid is now always visible. -->
                                    <TextBlock x:Name="FanCurveLockedAxisHint"
                                               Visibility="Collapsed"
                                               FontSize="9" Foreground="#888888"
                                               HorizontalAlignment="Center"/>

                                    <!-- Current temperature display. The prefix label swaps between
                                         "Fan Sensor Temp:" (firmware path) and "CPU Temp:" (EC override
                                         path) based on the Unlock Fan Curve Override toggle so the
                                         displayed value always matches the sensor that's actually
                                         driving the curve evaluation. -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="CurrentTempPrefixLabel" Text="Fan Sensor Temp: " FontSize="12" Foreground="#888888"/>
                                        <TextBlock x:Name="CurrentTempLabel" Text="--°C" FontSize="12" Foreground="#FF8800" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- EC Floor legend — only meaningful when firmware drives the
                                         fan, so collapse it when the EC override loop is active. -->
                                    <StackPanel x:Name="ECFloorLegendPanel" Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Center">
                                        <Line X1="0" Y1="0" X2="20" Y2="0" Stroke="#FF8800" StrokeThickness="2" StrokeDashArray="4,2" VerticalAlignment="Center"/>
                                        <TextBlock Text=" EC Protection Floor" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Battery Section Header -->
                        <TextBlock Text="Battery" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Battery Charge Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Charge Limit (80%)" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Limit battery charge to extend lifespan"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionChargeLimitToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False"/>
                            </Grid>
                        </Border>

                        <!-- LABS Section Header -->
                        <TextBlock Text="Labs" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Labs Description -->
                        <TextBlock Text="Experimental features - use at your own risk"
                                   Style="{StaticResource CardCaptionStyle}"
                                   Margin="0,4,0,8"/>

                        <!-- Disable Legion Space Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Disable Legion Space Service" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Removes Legion L/R handling. May override TDP, remaps, fan curve. You can still open Legion Space for updates."
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button x:Name="ToggleDAServiceButton"
                                            Grid.Column="1"
                                            Content="Disable"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Click="ToggleDAServiceButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="DAServiceStatusText"
                                           Text="Checking..."
                                           FontSize="14"
                                           Foreground="#B9C0CC"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Fix Task View Bug Card (optional USB phantom-input fix) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Fix Task View Bug" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Optional — enable only if you have this bug: with a USB hub attached, after every boot Task View keeps opening (with a controller vibration) whenever you return to the desktop, until you replug a controller. Enable runs a one-time controller re-plug automatically after each restart to clear it."
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button x:Name="ToggleTaskViewFixButton"
                                            Grid.Column="1"
                                            Content="Enable"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Click="ToggleTaskViewFixButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="TaskViewFixStatusText"
                                           Text="Checking..."
                                           FontSize="14"
                                           Foreground="#B9C0CC"
                                           Margin="0,8,0,0"/>
                                <Button x:Name="TaskViewFixRunNowButton"
                                        Content="Run fix now (one-time)"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Click="TaskViewFixRunNowButton_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Driver Updates Card (Lenovo): machine type + installed BIOS +
                             direct link to the correct Lenovo downloads page, with a
                             best-effort live driver list fetched from pcsupport.lenovo.com -->
                        <TextBlock Text="Driver Updates" Style="{StaticResource SectionHeaderStyle}"/>
                        <Border x:Name="DriverUpdatesCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Lenovo Driver Updates" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Check Lenovo's driver page for this machine type"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="DriverUpdatesExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="True"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="DriverUpdatesExpandToggle_Click">
                                        <FontIcon x:Name="DriverUpdatesExpandIcon" Glyph="&#xE70E;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="DriverUpdatesContent" Spacing="10" Margin="0,12,0,0">
                                    <!-- Machine info: two rows of label:value -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Machine type" FontSize="13" Foreground="#B9C0CC"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DriverUpdatesMachineType" Text="—" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Model" FontSize="13" Foreground="#B9C0CC" Margin="0,4,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DriverUpdatesModel" Text="—" FontSize="13" Foreground="#FFFFFF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Installed BIOS" FontSize="13" Foreground="#B9C0CC" Margin="0,4,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DriverUpdatesBios" Text="—" FontSize="13" Foreground="#FFFFFF" Margin="0,4,0,0"/>
                                    </Grid>

                                    <!-- Actions row -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="DriverUpdatesCheckButton"
                                                Content="Check for updates"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="DriverUpdatesCheckButton_Click"/>
                                        <Button x:Name="DriverUpdatesUpdateAllButton"
                                                Content="Update all"
                                                Visibility="Collapsed"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="DriverUpdatesUpdateAllButton_Click"/>
                                        <Button x:Name="DriverUpdatesOpenPageButton"
                                                Content="Open Lenovo driver page"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="DriverUpdatesOpenPageButton_Click"/>
                                    </StackPanel>

                                    <TextBlock x:Name="DriverUpdatesStatusText"
                                               Text="Click Check for updates to query Lenovo."
                                               FontSize="11"
                                               Foreground="#888888"
                                               TextWrapping="Wrap"/>

                                    <!-- Category filter: utilities/diagnostics hidden by default -->
                                    <CheckBox x:Name="DriverUpdatesShowUtilitiesCheckbox"
                                              Content="Show utilities and diagnostics"
                                              IsChecked="False"
                                              FontSize="12"
                                              Foreground="#B9C0CC"
                                              Checked="DriverUpdatesShowUtilitiesCheckbox_Changed"
                                              Unchecked="DriverUpdatesShowUtilitiesCheckbox_Changed"/>

                                    <!-- Auto-install + banner-hide preferences. Persisted in
                                         LocalSettings. UpdateOnStart triggers Update-all the
                                         moment the helper pushes a non-zero driver-update count. -->
                                    <CheckBox x:Name="DriverUpdatesUpdateOnStartCheckbox"
                                              Content="Check for driver updates on start"
                                              IsChecked="True"
                                              FontSize="12"
                                              Foreground="#B9C0CC"
                                              Checked="DriverUpdatesUpdateOnStartCheckbox_Changed"
                                              Unchecked="DriverUpdatesUpdateOnStartCheckbox_Changed"/>
                                    <CheckBox x:Name="DriverUpdatesHideBannerCheckbox"
                                              Content="Hide driver-update banner on Quick tab"
                                              IsChecked="False"
                                              FontSize="12"
                                              Foreground="#B9C0CC"
                                              Checked="DriverUpdatesHideBannerCheckbox_Changed"
                                              Unchecked="DriverUpdatesHideBannerCheckbox_Changed"/>

                                    <!-- Live driver list (populated when the pcsupport API responds) -->
                                    <ItemsControl x:Name="DriverUpdatesList" Visibility="Collapsed">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1A2E" CornerRadius="4" Padding="10,8" Margin="0,4,0,0">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" Foreground="#FFFFFF" TextWrapping="Wrap"/>
                                                            <!-- Status chip: color comes from StatusColor ("#55C855" up-to-date, "#FFB060" update, "#888" unknown/not-installed) -->
                                                            <Border Grid.Column="1" Background="{Binding StatusColor}" CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="10" Foreground="#FFFFFF"/>
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,2,0,0">
                                                            <Run Text="{Binding Category}"/><Run Text=" • "/><Run Text="{Binding Severity}"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="11" Foreground="#B9C0CC" TextWrapping="Wrap" Margin="0,2,0,0">
                                                            <Run Text="Installed:"/><Run Text=" "/><Run Text="{Binding InstalledVersion}"/><Run Text="  →  "/><Run Text="Latest:"/><Run Text=" "/><Run Text="{Binding Version}"/>
                                                        </TextBlock>
                                                        <Grid Margin="0,4,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding ReleaseDate, FallbackValue=''}" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1"
                                                                    Content="{Binding InstallButtonLabel}"
                                                                    Tag="{Binding DownloadUrl}"
                                                                    Visibility="{Binding InstallButtonVisibility}"
                                                                    Style="{StaticResource ModernButtonStyle}"
                                                                    FontSize="11"
                                                                    Padding="10,4"
                                                                    Click="DriverInstallButton_Click"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GPD TAB -->
                <ScrollViewer x:Name="GPDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Device Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="GPDDeviceNameText" Text="GPD Device" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="GPDConnectionStatusText"
                                           Text="Detecting..."
                                           FontSize="14"
                                           Foreground="#888888"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Fan Control Card (Win 5 specific) -->
                        <StackPanel x:Name="GPDFanControlSection" Visibility="Collapsed">
                            <TextBlock Text="Fan Control" Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <!-- Header: Fan Settings + RPM -->
                                    <TextBlock Text="Fan Settings" Style="{StaticResource CardTitleStyle}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Fan: " Style="{StaticResource CardCaptionStyle}"/>
                                        <TextBlock x:Name="GPDFanRPMText" Text="-- RPM" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>

                                    <!-- Fan Curve Toggle -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Fan Curve" Foreground="#FFFFFF" FontSize="13"/>
                                            <TextBlock Text="Software-controlled fan curve based on CPU temperature"
                                                       FontSize="12" Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="GPDFanCurveToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"
                                                      Toggled="GPDFanCurveToggle_Toggled"
                                                      XYFocusUp="{x:Bind GPDNavItem}"/>
                                    </Grid>

                                    <!-- Manual Fan Controls (visible when curve OFF) -->
                                    <StackPanel x:Name="GPDManualFanContent">
                                        <!-- Fan Mode Toggle -->
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Fan Mode" Foreground="#FFFFFF" FontSize="13"/>
                                                <TextBlock x:Name="GPDFanModeText"
                                                           Text="Auto"
                                                           FontSize="12"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="GPDFanModeToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"
                                                          Toggled="GPDFanModeToggle_Toggled"/>
                                        </Grid>

                                        <!-- Fan Speed Slider (visible only in manual mode) -->
                                        <StackPanel x:Name="GPDFanSpeedSection" Margin="0,16,0,0" Visibility="Collapsed">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Fan Speed" Grid.Column="0" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
