                                                          StrokeThickness="2"
                                                          StrokeDashArray="4,2"
                                                          Visibility="Collapsed"/>

                                                    <!-- Control points created in code-behind -->
                                                </Canvas>
                                            </Grid>

                                            <!-- X-axis labels (30°C to 100°C) -->
                                            <Grid Margin="30,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
